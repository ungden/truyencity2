!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local logs
/logs/

# diagnostic scripts with hardcoded secrets (local-only)
scripts/audit-pipeline.ts
scripts/check-results.ts
scripts/trigger-write-chapters.ts

# Phase R/S/T (2026-05-15) — debug + trace scripts not for production CI
scripts/_*.ts

# Temporary audit + backfill output directories
/tmp/backfill/
/tmp/backfill-orch/
/tmp/backfill-length/
/tmp/setup-v3/
/tmp/mat-the-audit/
/tmp/probe/
/tmp/title-audit/
/backups/legacy-archive/

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# generated story output
/chapters/
.codex/story-runs/
.codex/automation-runs/
.automation/
/automation-runs/
public/covers/*
!public/covers/flagship-first-30/
!public/covers/flagship-first-30/**

# typescript
*.tsbuildinfo
next-env.d.ts

