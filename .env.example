# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Cron Secret (generate with: openssl rand -hex 32)
CRON_SECRET=your_cron_secret_here

# Autonomous flagship factory. Keep disabled until the portfolio is provisioned.
# Once enabled, missing provider keys return waitingForProvider without claiming
# a job or touching canon.
# Projects must additionally set style_directives.factory_enabled=true,
# publication_mode=automatic and pipeline_version=flagship_v2.
FLAGSHIP_FACTORY_ENABLED=0
FLAGSHIP_FACTORY_CONCURRENCY=8
FLAGSHIP_FACTORY_LEASE_SECONDS=900

# Optional only when an explicit model route starts with deepseek-.
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Notes:
# - .env.local is gitignored and should contain your actual keys for local development
# - For Vercel production, add these same variables in the Vercel dashboard
# - NEXT_PUBLIC_* variables are exposed to the browser (use for client-side code)
# - SUPABASE_SERVICE_ROLE_KEY is server-only (never expose to client)
